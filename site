<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PORTFOLIO</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #082647f5;
    --bg2: #050f1e;
    --cyan: #a693d1;
    --cyan2: #d636d6;
    --green: hwb(332 33% 11%);
    --orange: #ff6b00;
    --red: #ff2244;
    --white: #e8f4ff;
    --gray: #4a6080;
    --grid: rgba(0,245,255,0.04);
    --border: rgba(0,245,255,0.15);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: 'Rajdhani', sans-serif;
    font-size: 16px;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* GRID BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,245,255,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* SCAN LINE */
  .scanline {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity: 0.5;
    animation: scan 6s linear infinite;
    z-index: 999;
    pointer-events: none;
  }
  @keyframes scan { 0% { top: 0; } 100% { top: 100vh; } }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 60px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(2,8,16,0.85);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .nav-logo {
    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 900;
    color: var(--cyan);
    letter-spacing: 3px;
    text-decoration: none;
    position: relative;
  }
  .nav-logo span { color: var(--green); }

  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--gray);
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0; right: 0;
    height: 1px;
    background: var(--cyan);
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .nav-links a:hover { color: var(--cyan); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--green);
  }
  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

  /* SECTION BASE */
  section {
    position: relative;
    z-index: 1;
    padding: 100px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::before {
    content: '';
    width: 24px; height: 1px;
    background: var(--cyan);
  }

  .section-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 48px;
  }

  /* =================== HERO =================== */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 64px;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 60px;
    padding-right: 60px;
  }

  .hero-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--cyan);
    letter-spacing: 4px;
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.3s;
  }

  .hero-name {
    font-family: 'Orbitron', monospace;
    font-size: clamp(42px, 8vw, 96px);
    font-weight: 900;
    line-height: 0.95;
    margin-bottom: 16px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.5s;
  }

  .hero-name .glitch {
    position: relative;
    color: var(--white);
    display: inline-block;
  }
  .hero-name .glitch::before,
  .hero-name .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%;
  }
  .hero-name .glitch::before {
    color: var(--cyan);
    animation: glitch1 3s infinite;
    clip-path: polygon(0 0, 100% 0, 100% 40%, 0 40%);
  }
  .hero-name .glitch::after {
    color: var(--red);
    animation: glitch2 3s infinite;
    clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%);
  }

  @keyframes glitch1 {
    0%,90%,100% { transform: none; opacity: 0; }
    91% { transform: translateX(-4px); opacity: 1; }
    93% { transform: translateX(4px); opacity: 1; }
    95% { transform: translateX(-2px); opacity: 0.8; }
    97% { transform: none; opacity: 0; }
  }
  @keyframes glitch2 {
    0%,88%,100% { transform: none; opacity: 0; }
    89% { transform: translateX(4px); opacity: 1; }
    92% { transform: translateX(-4px); opacity: 1; }
    94% { transform: translateX(2px); opacity: 0.8; }
    96% { transform: none; opacity: 0; }
  }

  .hero-role {
    font-family: 'Share Tech Mono', monospace;
    font-size: clamp(14px, 2vw, 20px);
    color: var(--cyan);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.7s;
  }
  .hero-role span { color: var(--green); }

  .hero-bio {
    max-width: 560px;
    font-size: 17px;
    line-height: 1.7;
    color: rgba(232,244,255,0.65);
    margin-bottom: 48px;
    font-weight: 300;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.9s;
  }

  .hero-ctas {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.1s;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-decoration: none;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--cyan);
    transform: translateX(-100%);
    transition: transform 0.3s;
    z-index: -1;
  }
  .btn-primary:hover { color: var(--bg); }
  .btn-primary:hover::before { transform: translateX(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--gray);
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-decoration: none;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
  }
  .btn-secondary:hover { border-color: var(--gray); color: var(--white); }

  .hero-stats {
    position: absolute;
    right: 60px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 32px;
    opacity: 0;
    animation: fadeLeft 0.8s ease forwards 1.2s;
  }
  .stat-item { text-align: right; }
  .stat-number {
    font-family: 'Orbitron', monospace;
    font-size: 36px;
    font-weight: 900;
    color: var(--cyan);
    line-height: 1;
  }
  .stat-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 2px;
    margin-top: 4px;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeLeft {
    from { opacity: 0; transform: translateY(-50%) translateX(30px); }
    to { opacity: 1; transform: translateY(-50%) translateX(0); }
  }

  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 60px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 2px;
    animation: fadeUp 1s ease forwards 1.5s;
    opacity: 0;
  }
  .scroll-line {
    width: 40px; height: 1px;
    background: var(--gray);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: var(--cyan);
    animation: scrollAnim 2s ease-in-out infinite;
  }
  @keyframes scrollAnim { 0%{left:-100%} 100%{left:100%} }

  /* =================== SOBRE =================== */
  #sobre { padding-top: 60px; }

  .sobre-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .sobre-text p {
    font-size: 17px;
    line-height: 1.8;
    color: rgba(232,244,255,0.7);
    font-weight: 300;
    margin-bottom: 20px;
  }
  .sobre-text p strong { color: var(--cyan); font-weight: 600; }

  .skills-panel {
    background: rgba(0,245,255,0.02);
    border: 1px solid var(--border);
    padding: 32px;
  }

  .skills-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .skill-row {
    margin-bottom: 20px;
  }
  .skill-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--white);
  }
  .skill-pct { color: var(--cyan); }
  .skill-bar {
    height: 2px;
    background: rgba(255,255,255,0.06);
    position: relative;
  }
  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), var(--green));
    position: relative;
    animation: fillBar 1.5s ease forwards;
    transform-origin: left;
  }
  .skill-fill::after {
    content: '';
    position: absolute;
    right: 0; top: -3px;
    width: 8px; height: 8px;
    background: var(--green);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--green);
  }
  @keyframes fillBar { from{width:0} }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }
  .tech-tag {
    padding: 6px 14px;
    border: 1px solid var(--border);
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--gray);
    letter-spacing: 1px;
    transition: all 0.3s;
  }
  .tech-tag:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    background: rgba(0,245,255,0.05);
  }

  /* =================== PROJETOS =================== */
  #projetos { border-top: 1px solid var(--border); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .project-card {
    background: var(--bg);
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.3s;
  }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--green));
    transform: scaleX(0);
    transition: transform 0.4s;
  }
  .project-card:hover { background: rgba(0,245,255,0.03); }
  .project-card:hover::before { transform: scaleX(1); }

  .project-num {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: var(--border);
    letter-spacing: 2px;
    margin-bottom: 24px;
  }

  .project-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .project-title {
    font-family: 'Orbitron', monospace;
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .project-desc {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(232,244,255,0.5);
    font-weight: 300;
    margin-bottom: 24px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .project-tag {
    padding: 3px 10px;
    background: rgba(0,245,255,0.07);
    border: 1px solid rgba(0,245,255,0.15);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--cyan);
    letter-spacing: 1px;
  }

  .project-link {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--gray);
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 0.3s;
  }
  .project-link:hover { color: var(--cyan); }
  .project-link .arrow { transition: transform 0.3s; }
  .project-link:hover .arrow { transform: translateX(4px); }

  /* =================== CERTIFICAÇÕES =================== */
  #certificacoes { border-top: 1px solid var(--border); }

  .certs-list { display: flex; flex-direction: column; gap: 1px; }

  .cert-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 32px;
    padding: 28px 32px;
    background: var(--bg2);
    border: 1px solid transparent;
    transition: all 0.3s;
    cursor: default;
  }
  .cert-item:hover {
    border-color: var(--border);
    background: rgba(0,245,255,0.02);
  }

  .cert-badge {
    width: 56px; height: 56px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    background: rgba(0,245,255,0.04);
    flex-shrink: 0;
  }

  .cert-info {}
  .cert-name {
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
  }
  .cert-issuer {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--gray);
    letter-spacing: 1px;
  }

  .cert-meta { text-align: right; }
  .cert-year {
    font-family: 'Orbitron', monospace;
    font-size: 20px;
    font-weight: 900;
    color: var(--cyan);
    opacity: 0.4;
    line-height: 1;
    margin-bottom: 6px;
  }
  .cert-status {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--green);
    letter-spacing: 2px;
  }

  /* =================== CURRÍCULO =================== */
  #curriculo { border-top: 1px solid var(--border); }

  .timeline { position: relative; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    padding-left: 48px;
    padding-bottom: 48px;
    position: relative;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -4px; top: 8px;
    width: 9px; height: 9px;
    background: var(--cyan);
    border: 2px solid var(--bg);
    box-shadow: 0 0 12px var(--cyan);
  }

  .timeline-date {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .timeline-role {
    font-family: 'Orbitron', monospace;
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }

  .timeline-company {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--green);
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .timeline-desc {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(232,244,255,0.55);
    font-weight: 300;
    max-width: 600px;
  }

  .download-cv {
    margin-top: 48px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 40px;
    background: transparent;
    border: 1px solid var(--green);
    color: var(--green);
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }
  .download-cv::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--green);
    transform: translateX(-100%);
    transition: transform 0.3s;
    z-index: -1;
  }
  .download-cv:hover { color: var(--bg); }
  .download-cv:hover::before { transform: translateX(0); }

  /* =================== CONTATO =================== */
  #contato { border-top: 1px solid var(--border); }

  .contato-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contato-info h3 {
    font-family: 'Orbitron', monospace;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--white);
  }
  .contato-info p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(232,244,255,0.55);
    font-weight: 300;
    margin-bottom: 40px;
  }

  .contact-links { display: flex; flex-direction: column; gap: 16px; }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
    color: var(--gray);
    text-decoration: none;
    transition: color 0.3s;
    letter-spacing: 1px;
  }
  .contact-link:hover { color: var(--cyan); }
  .contact-icon {
    width: 36px; height: 36px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    transition: border-color 0.3s;
  }
  .contact-link:hover .contact-icon { border-color: var(--cyan); }

  /* FORM */
  .contato-form { display: flex; flex-direction: column; gap: 20px; }

  .form-group { position: relative; }
  .form-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--gray);
    letter-spacing: 3px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }
  .form-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--border);
    padding: 14px 16px;
    color: var(--white);
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    outline: none;
    transition: border-color 0.3s;
  }
  .form-input:focus { border-color: var(--cyan); }
  .form-input::placeholder { color: var(--gray); opacity: 0.5; }
  textarea.form-input { resize: vertical; min-height: 120px; }

  .form-submit {
    padding: 16px;
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .form-submit::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--cyan);
    transform: translateX(-100%);
    transition: transform 0.3s;
    z-index: 0;
  }
  .form-submit span { position: relative; z-index: 1; transition: color 0.3s; }
  .form-submit:hover span { color: var(--bg); }
  .form-submit:hover::before { transform: translateX(0); }

  /* =================== FOOTER =================== */
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 40px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 100%;
  }
  .footer-logo {
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    font-weight: 900;
    color: var(--cyan);
    opacity: 0.5;
    letter-spacing: 3px;
  }
  .footer-copy {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
